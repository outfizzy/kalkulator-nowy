#top .span_9>.slide-out-widget-area-toggle a.using-label, #top ul .slide-out-widget-area-toggle a.using-label, body[data-header-search=false] #header-outer[data-has-menu=false][data-cart=false] #top nav ul .slide-out-widget-area-toggle a.using-label {
    margin-top: -3px;
}

 ul {
    margin-left: 15px;
    margin-bottom: 30px;
}

ul li {
    list-style: square;
    list-style-position: outside;
}

li::marker {
  color: #f39200;
}

body[data-header-resize="0"] .container-wrap, body[data-header-resize="0"] .project-title {
    margin-top: 0;
    padding-top: 0px;
}

.nf-error-msg, .ninja-forms-req-symbol {
    color: #ff6600!important;
}

ul.sub-menu.tracked-pos{
    left: 0px !important;
}

/* harmonica kleuren*/

.toggle.extra-color-1 a {
  background-color: #333333;
  color:#f39200;
}

.toggle.extra-color-2 a {
  background-color: #f39200;
  color:#ffffff;
}
.toggle>.toggle-title a i {
    color: #ffffff;
}

.toggle>.toggle-title a:hover {
    background-color: #333333;
}

.toggle.open.extra-color-2 > .toggle-title a, .nectar-hor-list-item[data-hover-effect="full_border"][data-color="extra-color-2"] .nectar-list-item-btn:hover {
    background-color: #333333;
}

.ninja-forms-field.mm-bg {
background-image: url("/wp-content/plugins/hab-pricecalculator/mm.png") !important;
  background-repeat: no-repeat !important;
  background-position: left !important;
  background-size: contain !important;
}

/**Tijdelijk H+B uit in nf*/

.nf-form-content div.nf-row:first-child {
  display: none;
}
#hab-pricecalc-price {display: none}

#hab-pricecalc-price .extra {
    display: block;
}

.page-id-4995 #hab-pricecalc-price,
.page-id-4995 .nf-form-content div.nf-row:first-child {
  display: block;
}

/* einde harmonica kleuren*/
